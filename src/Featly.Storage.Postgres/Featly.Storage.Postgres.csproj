<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Featly.Storage.Postgres</RootNamespace>
    <AssemblyName>Featly.Storage.Postgres</AssemblyName>
    <Description>Featly — PostgreSQL IFeatlyStore implementation via EF Core (Npgsql). DbContext is internal to this assembly; consumers depend only on IFeatlyStore.</Description>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Featly.Abstractions\Featly.Abstractions.csproj" />
    <ProjectReference Include="..\Featly.Storage.Abstractions\Featly.Storage.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared, provider-agnostic EF Core helpers (compiled into each relational
         provider; ADR-0026 keeps the DbContext per provider). -->
    <Compile Include="..\Shared\Storage\EfPendingChangeStore.cs" Link="Stores\Shared\EfPendingChangeStore.cs" />
    <Compile Include="..\Shared\Storage\EfWebhookDeliveryStore.cs" Link="Stores\Shared\EfWebhookDeliveryStore.cs" />
    <Compile Include="..\Shared\Storage\EfWebhookStore.cs" Link="Stores\Shared\EfWebhookStore.cs" />
    <Compile Include="..\Shared\Storage\EfAuditStore.cs" Link="Stores\Shared\EfAuditStore.cs" />
    <Compile Include="..\Shared\Storage\EfEnvironmentStore.cs" Link="Stores\Shared\EfEnvironmentStore.cs" />
    <Compile Include="..\Shared\Storage\EfFeatlyStore.cs" Link="Stores\Shared\EfFeatlyStore.cs" />
    <Compile Include="..\Shared\Storage\EfMigrationRunner.cs" Link="Stores\Shared\EfMigrationRunner.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <!-- Design is a build-time-only dependency so `dotnet ef migrations`
         works inside this project. PrivateAssets stops it from leaking to
         consumers of the NuGet package. -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" PrivateAssets="All" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
  </ItemGroup>

</Project>
