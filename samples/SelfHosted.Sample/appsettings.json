{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Featly": {
    "Server": {
      "AdminApiKey": "dev-admin-replace-me",
      "SdkApiKey": "dev-sdk-replace-me",
      "AutoCreateDefaultProject": true,
      "DefaultProjectKey": "default",
      "DefaultEnvironmentKey": "development"
    },
    "Storage": {
      "Sqlite": {
        "ConnectionString": "Data Source=featly.db",
        "AutoMigrate": true
      }
    },
    "Telemetry": {
      "Enabled": false,
      "Traces": true,
      "Metrics": true,
      "ServiceName": "Featly.SelfHosted",
      "OtlpEndpoint": "http://localhost:4317",
      "OtlpProtocol": "Grpc"
    }
  }
}
